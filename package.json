{
  "name": "socos",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "services/api",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type:check": "turbo run type:check",
    "security:regression": "node scripts/security-regression.mjs",
    "clean": "turbo run clean"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
