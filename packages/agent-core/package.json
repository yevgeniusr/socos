{
  "name": "@socos/agent-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./src/tools/index.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.cjs",
      "default": "./dist/tools/index.js"
    },
    "./agent-interface": {
      "types": "./src/agent-interface/index.ts",
      "import": "./dist/agent-interface/index.js",
      "require": "./dist/agent-interface/index.cjs",
      "default": "./dist/agent-interface/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run src",
    "type:check": "tsc --noEmit",
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@socos/eslint-config": "workspace:*",
    "@socos/typescript-config": "workspace:*",
    "@types/node": "^22.19.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.0"
  }
}
