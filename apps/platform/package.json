{
  "name": "@socos/platform",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3000 --host",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.tsx src",
    "type:check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@socos/shared": "workspace:*",
    "posthog-js": "^1.371.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@socos/eslint-config": "workspace:*",
    "@socos/typescript-config": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@eslint/js": "^9.39.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
