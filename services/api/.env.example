# ===========================================
# SOCOS API - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/socos?schema=public"

# App
APP_URL="https://socos.app"
NODE_ENV="development"

# ===========================================
# AI AGENTS (via OpenRouter)
# ===========================================
# OpenRouter API for AI-powered features (summaries, notes, relationship health)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ===========================================
# EMAIL - Resend
# ===========================================
# Sign up at https://resend.com
# Resend is a modern email API that's simple to use
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="SOCOS <noreply@socos.app>"

# ===========================================
# SMS - Twilio
# ===========================================
# Sign up at https://www.twilio.com
# Twilio provides reliable SMS delivery globally
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ===========================================
# JWT (for authentication)
# ===========================================
# Required: at least 32 characters. Generate a unique secret for each environment.
JWT_SECRET=

# Registration is disabled unless one or more comma-separated codes are configured.
INVITE_CODES=

# ===========================================
# ===========================================
# ERROR MONITORING - Sentry
# ===========================================
# Get your DSN at https://sentry.io
# Leave empty to disable error monitoring
SENTRY_DSN=""

# Optional: External Services
# ===========================================

# Clearbit (for contact enrichment)
CLEARBIT_API_KEY="..."

# LinkedIn API (for professional info)
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."

# Calendar, Location, Event Runtime Gates
# Disabled by default. Use synthetic/local values outside production.
CALENDAR_SYNC_ENABLED=false
LOCATION_INGEST_ENABLED=false
EVENT_DISCOVERY_ENABLED=false
EVENT_BRIEF_ENABLED=false

# Google Calendar (runtime only; do not expose via frontend public env vars)
GOOGLE_CALENDAR_CLIENT_ID="synthetic-calendar-client-id"
GOOGLE_CALENDAR_CLIENT_SECRET="synthetic-calendar-client-secret"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3001/api/integrations/google-calendar/callback"
GOOGLE_CALENDAR_WEBHOOK_URL="https://calendar-location.test.invalid/google/webhook"
GOOGLE_CALENDAR_SETTINGS_RESULT_URL="http://localhost:3000/dashboard/integrations"

# Personal data encryption/index keys (runtime only)
# Generate independent canonical base64-encoded 32-byte keys per environment.
PERSONAL_DATA_KEYS='[{"version":1,"key":"REPLACE_WITH_BASE64_32_BYTE_AES_KEY"}]'
PERSONAL_DATA_ACTIVE_KEY_VERSION=1
PERSONAL_DATA_INDEX_KEY="REPLACE_WITH_BASE64_32_BYTE_INDEX_KEY"

# Public event source host allowlist. Empty disables event source creation/polling.
EVENT_SOURCE_ALLOWED_HOSTS=

# Cal.com (for meeting scheduling)
CAL_COM_API_KEY="..."
