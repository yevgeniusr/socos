{
  "name": "@socos/api",
  "version": "0.1.0",
  "description": "SOCOS API - NestJS Backend",
  "author": "yevgeniusr",
  "private": true,
  "license": "MIT",
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "files": [
    "dist",
    ".env.*"
  ],
  "scripts": {
    "build": "nest build",
    "build:watch": "nest build --watch",
    "dev": "run-p build:watch start",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node --no-warnings=ExperimentalWarning --loader ts-node/esm ./src/main.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --no-warnings=ExperimentalWarning --loader ts-node/esm ./dist/main.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.ts\" --parser-options project:./tsconfig.eslint.json",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "type:check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.1.17",
    "@prisma/client": "^6.9.0",
    "@sentry/node": "^10.50.0",
    "@socos/agent-core": "workspace:*",
    "@socos/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lunar": "^2.0.0",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "prisma": "^6.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@socos/eslint-config": "workspace:*",
    "@socos/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
