generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER ====================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  avatar         String?
  passwordHash   String?
  xp             Int       @default(0)
  level          Int       @default(1)
  streakDays     Int       @default(0)
  lastActiveAt   DateTime?
  timeZone       String    @default("UTC")
  briefHourLocal Int       @default(8)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  contacts       Contact[]
  interactions   Interaction[]
  reminders      Reminder[]
  achievements   UserAchievement[]
  vaults         Vault[]
  sessions       Session[]
  briefBatches   BriefBatch[]
  briefItems     BriefItem[]
  quests         Quest[]
  briefFeedback  BriefFeedback[]
  xpTransactions XpTransaction[]
}

// ==================== VAULT ====================

model Vault {
  id          String   @id @default(cuid())
  name        String
  description String?
  isShared    Boolean  @default(false)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  contacts Contact[]
  members  VaultMember[]
}

model VaultMember {
  id        String   @id @default(cuid())
  vaultId   String
  vault     Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("member") // owner, admin, member
  createdAt DateTime @default(now())

  @@unique([vaultId, userId])
}

// ==================== CONTACT ====================

model Contact {
  id      String @id @default(cuid())
  vaultId String
  vault   Vault  @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Basic Info
  firstName  String
  lastName   String?
  middleName String?
  nickname   String?
  photo      String?
  bio        String?

  // Work
  company  String?
  jobTitle String?

  // Important Dates
  birthday    DateTime?
  anniversary DateTime?

  // Relationship Score (AI-calculated)
  relationshipScore    Int @default(50) // 0-100
  importance           Int @default(3)
  preferredCadenceDays Int @default(90)

  // Tags & Labels (JSON for flexibility)
  labels String[] @default([])
  tags   String[] @default([])
  groups String[] @default([])

  // Social Links
  socialLinks Json? // { linkedin, twitter, instagram, etc }

  // Metadata
  firstMetDate    DateTime?
  firstMetContext String?
  lastContactedAt DateTime?
  nextReminderAt  DateTime?

  // Import provenance
  isDemo          Boolean   @default(false)
  sourceSystem    String?
  sourceId        String?
  sourceUpdatedAt DateTime?
  importedAt      DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  interactions        Interaction[]
  reminders           Reminder[]
  contactFields       ContactField[]
  tasks               Task[]
  gifts               Gift[]
  activities          Activity[]
  contactCelebrations ContactCelebration[]

  @@unique([ownerId, sourceSystem, sourceId])
  // Indexes
  @@index([vaultId])
  @@index([ownerId])
  @@index([ownerId, isDemo])
  @@index([lastContactedAt])
  @@index([nextReminderAt])
}

// ==================== DAILY SOCIAL BRIEF ====================

model BriefBatch {
  id            String      @id @default(cuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  localDate     DateTime    @db.Date
  timeZone      String
  status        String      @default("generating")
  generatedAt   DateTime?
  schemaVersion String      @default("1.0")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         BriefItem[]
  quests        Quest[]

  @@unique([id, ownerId])
  @@unique([ownerId, localDate], map: "BriefBatch_ownerId_localDate_key")
  @@index([ownerId, status])
}

model BriefItem {
  id           String          @id @default(cuid())
  batchId      String
  batch        BriefBatch      @relation(fields: [batchId, ownerId], references: [id, ownerId], onDelete: Cascade)
  ownerId      String
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contactId    String?
  kind         String
  sourceType   String
  sourceId     String?
  rank         Int
  score        Float
  title        String
  reason       String
  evidence     Json
  status       String          @default("pending")
  snoozedUntil DateTime?
  actionedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  quests       Quest[]
  feedback     BriefFeedback[]

  @@unique([id, ownerId])
  @@unique([id, batchId, ownerId])
  @@unique([batchId, kind, rank])
  @@index([ownerId, contactId])
  @@index([ownerId, status, snoozedUntil])
}

model Quest {
  id             String          @id @default(cuid())
  batchId        String
  batch          BriefBatch      @relation(fields: [batchId, ownerId], references: [id, ownerId], onDelete: Cascade)
  ownerId        String
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  briefItemId    String
  briefItem      BriefItem       @relation(fields: [briefItemId, batchId, ownerId], references: [id, batchId, ownerId], onDelete: Cascade)
  title          String
  completionType String
  targetId       String
  xpReward       Int
  status         String          @default("pending")
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  feedback       BriefFeedback[]

  @@unique([id, ownerId])
  @@unique([batchId, briefItemId])
  @@index([ownerId, status])
}

model BriefFeedback {
  id             String     @id @default(cuid())
  ownerId        String
  owner          User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  briefItemId    String?
  briefItem      BriefItem? @relation(fields: [briefItemId, ownerId], references: [id, ownerId], onDelete: Cascade)
  questId        String?
  quest          Quest?     @relation(fields: [questId, ownerId], references: [id, ownerId], onDelete: Cascade)
  action         String
  reason         String?
  snoozedUntil   DateTime?
  idempotencyKey String
  requestHash    String
  createdAt      DateTime   @default(now())

  @@unique([ownerId, idempotencyKey], map: "BriefFeedback_ownerId_idempotencyKey_key")
  @@index([ownerId, briefItemId, createdAt])
}

model XpTransaction {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  amount     Int
  sourceType String
  sourceId   String
  createdAt  DateTime @default(now())

  @@unique([ownerId, sourceType, sourceId], map: "XpTransaction_ownerId_sourceType_sourceId_key")
  @@index([ownerId, createdAt])
}

// ==================== CONTACT FIELD ====================

model ContactField {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String // email, phone, address, website, etc
  value     String
  label     String? // work, personal, etc
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// ==================== INTERACTION ====================

model Interaction {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Type
  type String // call, message, meeting, note, email, social

  // Content
  title   String?
  content String? // The actual note/content
  summary String? // AI-generated summary

  // Metadata
  occurredAt DateTime @default(now())
  duration   Int? // in minutes, for calls/meetings
  location   String?

  // Gamification
  xpEarned Int @default(10)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([ownerId])
  @@index([occurredAt])
}

// ==================== REMINDER ====================

model Reminder {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Type
  type String // birthday, followup, custom, anniversary

  // Schedule
  title       String
  description String?
  scheduledAt DateTime
  completedAt DateTime?

  // Repeat
  repeatInterval String? // daily, weekly, monthly, yearly
  isRecurring    Boolean @default(false)

  // Status
  status String @default("pending") // pending, completed, skipped

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([ownerId])
  @@index([scheduledAt])
  @@index([status])
}

// ==================== TASK ====================

model Task {
  id        String   @id @default(cuid())
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String

  // Task Info
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium") // low, medium, high
  status      String    @default("pending") // pending, in_progress, completed

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([ownerId])
  @@index([contactId])
  @@index([status])
}

// ==================== GIFT ====================

model Gift {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Gift Info
  name        String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  url         String?
  imageUrl    String?

  // Status
  status  String    @default("idea") // idea, purchased, given
  givenAt DateTime?

  // Occasion
  occasion String? // birthday, christmas, anniversary, etc

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// ==================== ACHIEVEMENTS ====================

model Achievement {
  id          String  @id @default(cuid())
  code        String  @unique // e.g., "first_contact", "streak_master"
  name        String
  description String
  icon        String? // emoji or icon name
  xpReward    Int     @default(100)
  requirement Json // { type: "count", target: 1, object: "contacts" }

  // Relations
  unlockedBy UserAchievement[]

  createdAt DateTime @default(now())
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

// ==================== ACTIVITIES (Life Events) ====================

model Activity {
  id        String   @id @default(cuid())
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerId   String

  // Activity Info
  title       String
  description String?
  date        DateTime

  // Category
  category String // birth, death, wedding, graduation, job_change, moved, etc

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([contactId])
}

// ==================== CELEBRATION PACK ====================

model CelebrationPack {
  id          String   @id @default(cuid())
  ownerId     String? // null = system/default pack (available to all users)
  name        String
  description String?
  isDefault   Boolean  @default(false) // true for system packs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  celebrations Celebration[]

  @@index([ownerId])
}

// ==================== CELEBRATION ====================

model Celebration {
  id      String          @id @default(cuid())
  packId  String
  pack    CelebrationPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  ownerId String? // null = system/shared; if set, user owns their own copy

  // Core fields
  name        String
  description String?
  date        String // MM-DD format (recurring annual date)
  icon        String? // emoji

  // Optional: specific year date (for one-time events)
  fullDate DateTime? // YYYY-MM-DD for non-recurring

  // Category
  category String // religious, secular, cultural, personal

  // Calendar type: gregorian (fixed date), lunar (moves yearly), chinese (Chinese lunar calendar)
  calendarType String @default("gregorian")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contactCelebrations ContactCelebration[]

  @@index([packId])
  @@index([ownerId])
}

// ==================== CONTACT CELEBRATION (junction) ========================

model ContactCelebration {
  id            String      @id @default(cuid())
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  celebrationId String
  celebration   Celebration @relation(fields: [celebrationId], references: [id], onDelete: Cascade)
  ownerId       String // needed for auth scoping

  // Override the celebration date for this contact (e.g. if their Buddhist birthday is different)
  customDate DateTime?

  // Status: active = celebrate this for this contact, ignored = suppress
  status String @default("active") // active, ignored

  // Whether to generate a reminder for this contact's celebration
  shouldRemind Boolean @default(true)

  // Scheduled notification time (null = use default timing)
  sendAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, celebrationId])
  @@index([contactId])
  @@index([celebrationId])
  @@index([ownerId])
}

// ==================== SESSIONS (Auth) ====================

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ==================== DUNGEON MASTER ====================

model DungeonMasterScenario {
  id          String   @id @default(cuid())
  name        String
  archetype   String // "mystery", "adventure", "intimate"
  description String
  openingText String // AI prompt template for opening
  scenes      Json // Array of scene configs: [{ description, setting, expectedBeats }]
  xpReward    Int      @default(100)
  totalScenes Int      @default(3)
  createdAt   DateTime @default(now())

  sessions DMSession[]

  @@index([archetype])
}

model DMSession {
  id               String                @id @default(cuid())
  scenarioId       String
  scenario         DungeonMasterScenario @relation(fields: [scenarioId], references: [id])
  participants     String[] // array of user IDs (exactly 2 for MVP)
  currentScene     Int                   @default(0)
  status           String // "waiting" | "active" | "scene_submission" | "scene_review" | "debrief" | "completed" | "expired"
  currentNarrative String? // AI narration for current scene
  sceneStartedAt   DateTime?
  debrief          Json?
  debriefStartedAt DateTime?
  xpAwardedAt      DateTime?
  startedAt        DateTime?
  deadline         DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  responses DMSceneResponse[]

  @@index([scenarioId])
  @@index([status])
  @@index([deadline])
}

model DMSceneResponse {
  id          String    @id @default(cuid())
  sessionId   String
  session     DMSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String
  sceneIndex  Int
  content     String // User's response text (max 300 chars)
  submittedAt DateTime  @default(now())

  @@unique([sessionId, userId, sceneIndex])
  @@index([sessionId])
  @@index([userId])
}
